# --- AI Providers ---
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Analytics / Ads ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADSENSE_CLIENT=
ADSENSE_PUBLISHER_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false
NEXT_PUBLIC_ADSENSE_SLOT_HOME_HERO=
NEXT_PUBLIC_ADSENSE_SLOT_TOOLS_LIST=
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_DETAIL=
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_GENERATE_CTA=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_POST=
NEXT_PUBLIC_ADSENSE_SLOT_TEMPLATES_LIST=
NEXT_PUBLIC_ADSENSE_SLOT_TEMPLATE_DETAIL=
NEXT_PUBLIC_ADSENSE_SLOT_USE_CASES_LIST=
NEXT_PUBLIC_ADSENSE_SLOT_USE_CASE_DETAIL=
NEXT_PUBLIC_ADSENSE_SLOT_ABOUT=
NEXT_PUBLIC_ADSENSE_SLOT_MOBILE_STICKY_FOOTER=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Security ---
# Comma-separated list of allowed web origins for API requests
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
# Per-IP limit in middleware for all API routes (10-minute window)
API_RATE_LIMIT_GLOBAL=120
# Per-IP limit in /api/generate route (10-minute window)
API_GENERATE_RATE_LIMIT=25
# Max request body size allowed by middleware (bytes)
API_MAX_BODY_BYTES=20000
